{
  "version": 2,
  "builds": [
    {
      "src": "loginproject/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "runtime": "python3.9"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "loginproject/wsgi.py"
    }
  ],
  "installCommand": "pip install -r requirements.txt",
  "buildCommand": "chmod +x build.sh && ./build.sh",
  "outputDirectory": "staticfiles",
  "env": {
    "DJANGO_SETTINGS_MODULE": "loginproject.settings",
    "PYTHONPATH": "/vercel/path0"
  }
}
